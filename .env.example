RUST_LOG=info
API_BIND_ADDR=127.0.0.1:8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/basingamarket
REDIS_URL=redis://127.0.0.1:6379
NATS_URL=nats://127.0.0.1:4222
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_PROGRAM_ID=
SOLANA_REQUEST_TIMEOUT_MS=10000
PROJECTION_STORE_PATH=.dev/projection-store.json
# Fill these from apps/web.
# Existing devnet mint:
#   npm run setup:devnet-cash -- --cash-mint <mint> --vault-owner-keypair ~/.config/solana/basingamarket-devnet-vault-owner.json --write-env ../../.env
# New generated devnet mint:
#   npm run setup:devnet-cash -- --payer <keypair.json> --user <phantom_pubkey> --write-env ../../.env
SOLANA_CASH_MINT=
SOLANA_CASH_DECIMALS=6
SOLANA_DEPOSIT_VAULT_OWNER=
SOLANA_DEPOSIT_VAULT_TOKEN_ACCOUNT=
SOLANA_DEPOSIT_COMMITMENT=confirmed
SOLANA_SOL_DEPOSIT_ENABLED=true
SOLANA_SOL_TREASURY=
SOLANA_SOL_DEPOSIT_QUOTE_TTL_SECONDS=60
SOLANA_SOL_DEPOSIT_PRICE_SYMBOL=SOLUSDT
SOLANA_WITHDRAW_ENABLED=true
SOLANA_WITHDRAW_VAULT_OWNER_KEYPAIR=~/.config/solana/basingamarket-devnet-vault-owner.json
SOLANA_WITHDRAW_QUOTE_TTL_SECONDS=60
SOLANA_CASH_MINT_AUTHORITY_KEYPAIR=
DEV_SOL_DEPOSIT_REPAIR_ENABLED=false

# Must match the Solana-enabled Privy app used by apps/web.
# In Privy Dashboard, enable Wallet auth + Solana/SIWS login and allow
# http://localhost:5173 and http://127.0.0.1:5173 for local testing.
# For no-sign Google/e-mail app-cash actions, enable
# User management > Authentication > Advanced > Return user data in an identity token.
# If identity tokens are not enabled, the API can still verify wallet ownership by
# fetching the Privy user server-side when PRIVY_APP_SECRET is set.
PRIVY_APP_ID=
PRIVY_VERIFICATION_KEY=
PRIVY_APP_SECRET=
PRIVY_API_BASE_URL=
BM_WALLET_SESSION_SECRET=
