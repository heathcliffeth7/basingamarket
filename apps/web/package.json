{
  "name": "@basingamarket/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=11.14.1"
  },
  "scripts": {
    "setup": "npm ci && npm run patch:privy-key-warning",
    "dev": "node scripts/dev-full-stack.mjs",
    "dev:full": "node scripts/dev-full-stack.mjs",
    "dev:web": "API_INTERNAL_BASE_URL=http://127.0.0.1:8080 NEXT_PUBLIC_API_BASE_URL=/api/backend NEXT_PUBLIC_USE_MOCK_FALLBACK=true next dev -H 0.0.0.0 -p 5173",
    "dev:api": "cd ../.. && cargo run -p basingamarket-api",
    "deploy:devnet-program": "node scripts/deploy-devnet-program.mjs",
    "bootstrap:devnet-round": "node scripts/bootstrap-devnet-round.mjs",
    "bootstrap:devnet-live": "node scripts/devnet-live-round-keeper.mjs --once",
    "bootstrap:devnet-live:watch": "node scripts/devnet-live-round-keeper.mjs --watch",
    "build": "API_INTERNAL_BASE_URL=http://127.0.0.1:8080 NEXT_PUBLIC_USE_MOCK_FALLBACK=false next build",
    "preview": "next start -H 0.0.0.0 -p 5173",
    "setup:devnet-cash": "node scripts/setup-devnet-cash.mjs",
    "set:devnet-cash-mint": "node scripts/set-devnet-cash-mint.mjs",
    "reserve:devnet-cash": "node scripts/reserve-devnet-cash.mjs",
    "repair:sol-deposit": "node scripts/repair-sol-deposit.mjs",
    "withdraw:devnet-cash": "node scripts/withdraw-devnet-cash.mjs",
    "cash-buy:devnet": "node scripts/cash-buy-devnet.mjs",
    "secondary-resale:devnet": "node scripts/secondary-resale-devnet.mjs",
    "check": "API_INTERNAL_BASE_URL=http://127.0.0.1:8080 NEXT_PUBLIC_USE_MOCK_FALLBACK=true tsc --noEmit",
    "test:unit": "API_INTERNAL_BASE_URL=http://127.0.0.1:8080 NEXT_PUBLIC_USE_MOCK_FALLBACK=true vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit",
    "patch:privy-key-warning": "node scripts/patch-privy-key-warning.mjs"
  },
  "dependencies": {
    "@number-flow/react": "^0.6.0",
    "@privy-io/react-auth": "^3.23.1",
    "@solana-program/memo": "^0.10.0",
    "@solana-program/system": "^0.10.0",
    "@solana-program/token": "^0.9.0",
    "@solana/kit": "^5.5.1",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.100.9",
    "@walletconnect/universal-provider": "^2.22.4",
    "clsx": "latest",
    "liveline": "^0.0.7",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "latest",
    "tailwindcss": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "@types/qrcode": "^1.5.6"
  }
}
