# Use a Privy app with Wallet auth and Solana/SIWS login enabled.
# Add http://localhost:5173 and http://127.0.0.1:5173 to allowed origins/domains.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
